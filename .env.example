# === uText env flags ===

# Mode hidden app (decoy 2048 + PIN)
# true  = buka app muncul 2048, reveal chat pakai Morse ..- di judul -> error -> long-press "reset" -> PIN
# false = langsung chat (normal)
VITE_HIDDEN_APP=true

# PIN 4 digit buat reveal chat (cuma dipakai kalau VITE_HIDDEN_APP=true)
VITE_DECOY_PIN=1234

# VAPID public key (untuk Web Push bot reply) - isi dari `npx web-push generate-vapid-keys`
VITE_VAPID_PUBLIC_KEY=
